{
  "name": "tutorfin",
  "version": "0.0.0",
  "private": true,
  "description": "Financial literacy tutor app",
  "author": "westurner",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/westurner/tutorfin"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "clean": "npx rimraf node_modules && npm install",
    "preview": "vite preview",
    "test": "vitest run --coverage && pnpm --filter @tutorfin/ledgertext run test",
    "test:watch": "vitest",
    "test:report": "vitest run --coverage --coverage.reporter=json --coverage.reporter=json-summary --coverage.reporter=text --coverage.reportsDirectory=.tmp/coverage --reporter=json --outputFile=.tmp/coverage/test-results.json",
    "teste2e": "pnpm --filter @tutorfin/web run teste2e",
    "test:e2e:report": "playwright test",
    "testall": "pnpm --filter @tutorfin/ledgertext run test && pytest --cov=tutorfin --cov-report=xml --cov-report=term packages/ledgertext-py/tests"
  },
  "keywords": [],
  "dependencies": {
    "@react-three/a11y": "^3.0.0",
    "@react-three/drei": "^9.120.8",
    "@react-three/fiber": "^8.17.12",
    "@react-three/flex": "^1.0.1",
    "@react-three/postprocessing": "^2.16.6",
    "@react-three/rapier": "^1.5.0",
    "@tailwindcss/vite": "^4.0.9",
    "koota": "^0.2.3",
    "leva": "^0.10.0",
    "react": "^18.3.1",
    "react-animated-counter": "^1.7.9",
    "react-dom": "^18.3.1",
    "tailwindcss": "^4.0.9",
    "three": "^0.173.0",
    "typescript-eslint": "^8.25.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.21.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/three": "^0.173.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.21.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^16.0.0",
    "jsdom": "^29.1.0",
    "monocart-coverage-reports": "^2.12.11",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vite": "^6.2.0",
    "vitest": "^2.1.9"
  }
}